generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id                  Int       @id @default(autoincrement())
  walletAddress       String    @unique @db.VarChar(42)
  launchDate          DateTime?
  totalScore          Int       @default(0)
  currentStreak       Int       @default(0)
  longestStreak       Int       @default(0)
  lastPlayDate        DateTime?
  // Weekly reset fields
  lifetimeTotalScore  Int       @default(0)
  weeklyScore         Int       @default(0)
  weeklyStreak        Int       @default(0)
  weeklyLongestStreak Int       @default(0)
  lastResetWeekNumber Int? // Week number when player was last reset
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sessions GameSession[]
  streaks  PlayerStreak[]
}

model GameSession {
  id               Int      @id @default(autoincrement())
  playerId         Int
  score            Int
  playDate         DateTime
  weekNumber       Int? // Week number when game was played (for weekly resets and historical queries)
  streakMultiplier Float    @default(1.0)
  finalScore       Int
  gameData         String?  @db.Text
  createdAt        DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([playDate])
  @@index([weekNumber])
}

model PlayerStreak {
  id          Int      @id @default(autoincrement())
  playerId    Int
  streakDate  DateTime
  streakCount Int
  createdAt   DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([streakDate])
}

model WeeklyScoreSnapshot {
  id                  Int      @id @default(autoincrement())
  weekNumber          Int // Week number when snapshot was taken
  playerId            Int
  walletAddress       String   @db.VarChar(42)
  weeklyScore         Int // Weekly score before reset
  weeklyStreak        Int // Weekly streak before reset
  weeklyLongestStreak Int // Weekly longest streak before reset
  lifetimeTotalScore  Int // Lifetime total score at time of snapshot
  snapshotDate        DateTime @default(now()) // When the snapshot was taken

  @@index([weekNumber])
  @@index([playerId])
  @@index([walletAddress])
  @@index([snapshotDate])
}

enum GameState {
  ACTIVE
  IN_MAINTENANCE
  DISABLED
  HIDDEN
}

model GameSettings {
  id Int @id
  // Fields stored in WordPress ACF (single source of truth):
  // - launchDate (WordPress: game_launch_date)
  // - gameState (WordPress: game_state)
  // - weeklyResetEnabled (WordPress: weekly_reset_enabled)
  // - weeklyResetDay (WordPress: weekly_reset_day)
  // - weeklyResetHour (WordPress: weekly_reset_hour)
  // - weeklyResetMinute (WordPress: weekly_reset_minute)
  // These fields are fetched from WordPress and NOT stored in this table

  // Fields that remain in database (not in WordPress):
  streakBaseMultiplier  Float    @default(1.0)
  streakIncrementPerDay Float    @default(0.1)
  secondsPerDay         Int? // Debug/testing only (virtual days)
  currentWeekNumber     Int? // Current week number (updated when week changes, computed)
  // Referral settings
  referralExtraPlays    Int      @default(3) // Extra plays given when using a referral code
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ReferralCode {
  id              Int      @id @default(autoincrement())
  walletAddress   String   @unique @db.VarChar(42) // Wallet that used the referral code
  code            String   @db.VarChar(255) // The referral code used (slug from WordPress)
  extraPlaysUsed  Int      @default(0) // How many of the extra plays have been used
  extraPlaysTotal Int // Total extra plays granted (from game settings at time of use)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([walletAddress])
  @@index([code])
}

model BonusPlay {
  id              Int      @id @default(autoincrement())
  walletAddress   String   @db.VarChar(42)
  bonusType       String   @db.VarChar(50) // 'telegram' | 'base_farcaster'
  extraPlaysTotal Int // Extra plays granted for this bonus
  extraPlaysUsed  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([walletAddress, bonusType])
  @@index([walletAddress])
}

model BlockchainCheckIn {
  id            Int      @id @default(autoincrement())
  txHash        String   @unique @db.VarChar(66) // idempotency key — one credit per tx
  walletAddress String   @db.VarChar(42)
  blockNumber   BigInt
  checkInAt     DateTime // block.timestamp of the DailyCheckIn event (UTC)
  processedAt   DateTime @default(now())

  @@index([walletAddress])
  @@index([checkInAt])
}

model BaseAppCodeRedemption {
  id              Int      @id @default(autoincrement())
  walletAddress   String   @db.VarChar(42)
  code            String   @db.VarChar(255) // The code redeemed (from WordPress ACF)
  wpPostId        Int // WordPress post ID for reference
  extraPlaysTotal Int // Extra plays granted for this code
  extraPlaysUsed  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([walletAddress, code]) // Each wallet can only redeem each code once
  @@index([walletAddress])
  @@index([code])
}
